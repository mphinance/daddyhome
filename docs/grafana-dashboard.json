{
  "title": "TraderDaddy Pro — Long-term Trend",
  "uid": "traderdaddy-pro-trend",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-30d", "to": "now" },
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "title": "Market conviction (trend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "SELECT mean(\"value\") FROM \"traderdaddy_pro_conviction_market\" WHERE $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Symbol conviction vs. long-term quality",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "SELECT mean(\"value\") FROM \"traderdaddy_pro_conviction_symbol\" WHERE $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "resultFormat": "time_series"
        },
        {
          "query": "SELECT mean(\"value\") FROM \"traderdaddy_pro_long_term_quality\" WHERE $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Sentiment timeline",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "SELECT \"value\" FROM \"traderdaddy_pro_market_sentiment\" WHERE $timeFilter",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ]
    },
    {
      "id": 4,
      "title": "Legendary print frequency",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "SELECT \"value\" FROM \"traderdaddy_pro_legendary_print\" WHERE $timeFilter",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_INFLUXDB",
        "type": "datasource",
        "query": "influxdb",
        "current": {}
      }
    ]
  }
}
